<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Student Assignment Tracker — manage your assignments, deadlines, and stay on top of your studies." />
  <title>Student Assignment Tracker</title>

  <!-- Google Font: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    /* ── CSS Reset & Custom Properties ──────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #0f1117;
      --surface:      #1a1d27;
      --surface2:     #222638;
      --border:       rgba(255,255,255,0.08);
      --primary:      #6c63ff;
      --primary-glow: rgba(108,99,255,0.35);
      --secondary:    #00d4aa;
      --accent:       #ff6b6b;
      --warning:      #ffa94d;
      --text:         #e8eaf6;
      --text-muted:   #8b90a8;
      --card-radius:  16px;
      --transition:   0.25s cubic-bezier(0.4,0,0.2,1);
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* ── Animated gradient header ────────────────────────────────── */
    header {
      background: linear-gradient(135deg, #1a1d27 0%, #0f1117 50%, #1a1d27 100%);
      border-bottom: 1px solid var(--border);
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(12px);
    }

    header .logo-icon {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      border-radius: 12px;
      display: grid;
      place-items: center;
      font-size: 1.3rem;
      flex-shrink: 0;
      box-shadow: 0 0 20px var(--primary-glow);
    }

    header h1 {
      font-size: 1.4rem;
      font-weight: 700;
      background: linear-gradient(90deg, #fff, var(--primary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    header .subtitle {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-top: 1px;
    }

    /* ── Main layout ─────────────────────────────────────────────── */
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    /* ── Stats cards ─────────────────────────────────────────────── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--card-radius);
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: transform var(--transition), box-shadow var(--transition);
    }

    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.4);
    }

    .stat-icon {
      width: 46px; height: 46px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      font-size: 1.3rem;
      flex-shrink: 0;
    }

    .stat-icon.total    { background: rgba(108,99,255,0.18); }
    .stat-icon.done     { background: rgba(0,212,170,0.18); }
    .stat-icon.pending  { background: rgba(255,169,77,0.18); }
    .stat-icon.overdue  { background: rgba(255,107,107,0.18); }

    .stat-info .value {
      font-size: 1.8rem;
      font-weight: 800;
      line-height: 1;
    }

    .stat-info .label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-top: 2px;
    }

    /* ── Two-column layout (form + list) ─────────────────────────── */
    .content-grid {
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    @media (max-width: 800px) {
      .content-grid { grid-template-columns: 1fr; }
    }

    /* ── Card base ───────────────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--card-radius);
      padding: 1.5rem;
    }

    .card-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .card-title span.icon {
      font-size: 1.1rem;
    }

    /* ── Form styles ─────────────────────────────────────────────── */
    .form-group { margin-bottom: 1rem; }

    .form-group label {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.4rem;
    }

    .form-group input,
    .form-group select {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      padding: 0.65rem 0.9rem;
      font-size: 0.9rem;
      font-family: inherit;
      outline: none;
      transition: border-color var(--transition), box-shadow var(--transition);
    }

    .form-group input:focus,
    .form-group select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px var(--primary-glow);
    }

    .form-group input::placeholder { color: var(--text-muted); }

    /* native date picker color fix */
    .form-group input[type="date"]::-webkit-calendar-picker-indicator {
      filter: invert(0.7);
      cursor: pointer;
    }

    .btn-primary {
      width: 100%;
      background: linear-gradient(135deg, var(--primary), #8b7cf8);
      border: none;
      border-radius: 10px;
      color: #fff;
      font-family: inherit;
      font-size: 0.9rem;
      font-weight: 600;
      padding: 0.75rem 1.5rem;
      cursor: pointer;
      transition: opacity var(--transition), transform var(--transition), box-shadow var(--transition);
      box-shadow: 0 4px 18px var(--primary-glow);
      margin-top: 0.25rem;
    }

    .btn-primary:hover {
      opacity: 0.9;
      transform: translateY(-1px);
      box-shadow: 0 6px 24px var(--primary-glow);
    }

    .btn-primary:active { transform: translateY(0); }

    /* ── Error/alert banner ──────────────────────────────────────── */
    .alert {
      background: rgba(255,107,107,0.14);
      border: 1px solid rgba(255,107,107,0.4);
      border-radius: 10px;
      color: var(--accent);
      font-size: 0.85rem;
      padding: 0.65rem 1rem;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    /* ── Filter tabs ─────────────────────────────────────────────── */
    .filter-bar {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .filter-btn {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 30px;
      color: var(--text-muted);
      font-family: inherit;
      font-size: 0.8rem;
      font-weight: 500;
      padding: 0.4rem 1rem;
      cursor: pointer;
      text-decoration: none;
      transition: all var(--transition);
    }

    .filter-btn:hover { border-color: var(--primary); color: var(--text); }

    .filter-btn.active {
      background: var(--primary);
      border-color: var(--primary);
      color: #fff;
      box-shadow: 0 0 14px var(--primary-glow);
    }

    /* ── Assignment list ─────────────────────────────────────────── */
    .assignment-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .assignment-item {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
      position: relative;
      overflow: hidden;
    }

    .assignment-item::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      background: var(--primary);
      border-radius: 4px 0 0 4px;
      transition: background var(--transition);
    }

    .assignment-item.overdue { border-color: rgba(255,107,107,0.4); }
    .assignment-item.overdue::before { background: var(--accent); }

    .assignment-item.completed { opacity: 0.65; }
    .assignment-item.completed::before { background: var(--secondary); }

    .assignment-item:hover {
      transform: translateX(3px);
      box-shadow: 0 4px 20px rgba(0,0,0,0.35);
    }

    /* status toggle button */
    .status-toggle {
      width: 28px; height: 28px;
      border-radius: 50%;
      border: 2px solid var(--border);
      background: transparent;
      cursor: pointer;
      display: grid;
      place-items: center;
      transition: all var(--transition);
      flex-shrink: 0;
      color: transparent;
      font-size: 0.85rem;
    }

    .assignment-item.completed .status-toggle {
      background: var(--secondary);
      border-color: var(--secondary);
      color: #0f1117;
    }

    .status-toggle:hover {
      border-color: var(--secondary);
      background: rgba(0,212,170,0.15);
      color: var(--secondary);
    }

    .assignment-info { flex: 1; min-width: 0; }

    .assignment-title {
      font-size: 0.95rem;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .assignment-item.completed .assignment-title {
      text-decoration: line-through;
      color: var(--text-muted);
    }

    .assignment-meta {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 2px;
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.15rem 0.6rem;
      border-radius: 30px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .badge-overdue  { background: rgba(255,107,107,0.18); color: var(--accent); }
    .badge-pending  { background: rgba(255,169,77,0.18);  color: var(--warning); }
    .badge-completed{ background: rgba(0,212,170,0.18);   color: var(--secondary); }

    /* delete button */
    .btn-delete {
      background: transparent;
      border: 1px solid transparent;
      border-radius: 8px;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 1rem;
      padding: 0.35rem 0.5rem;
      transition: all var(--transition);
      flex-shrink: 0;
      line-height: 1;
    }

    .btn-delete:hover {
      background: rgba(255,107,107,0.14);
      border-color: rgba(255,107,107,0.4);
      color: var(--accent);
    }

    /* empty state */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--text-muted);
    }

    .empty-state .empty-icon {
      font-size: 3rem;
      margin-bottom: 0.75rem;
    }

    .empty-state p { font-size: 0.9rem; }

    /* ── Responsive tweaks ───────────────────────────────────────── */
    @media (max-width: 500px) {
      .stats-grid { grid-template-columns: 1fr 1fr; }
      header h1 { font-size: 1.1rem; }
    }

    /* ── Smooth fade-in animation ────────────────────────────────── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .assignment-item {
      animation: fadeUp 0.3s ease both;
    }
  </style>
</head>

<body>

<!-- ── HEADER ──────────────────────────────────────────────────── -->
<header>
  <div class="logo-icon">📚</div>
  <div>
    <h1>Student Assignment Tracker</h1>
    <div class="subtitle">Stay organised, never miss a deadline</div>
  </div>
</header>

<main>

  <!-- ── STATS ROW ─────────────────────────────────────────────── -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon total">📋</div>
      <div class="stat-info">
        <div class="value"><%= stats.totalCount %></div>
        <div class="label">Total</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon done">✅</div>
      <div class="stat-info">
        <div class="value"><%= stats.completedCount %></div>
        <div class="label">Completed</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon pending">⏳</div>
      <div class="stat-info">
        <div class="value"><%= stats.pendingCount %></div>
        <div class="label">Pending</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon overdue">🔥</div>
      <div class="stat-info">
        <div class="value"><%= stats.overdueCount %></div>
        <div class="label">Overdue</div>
      </div>
    </div>
  </div>

  <!-- ── MAIN GRID ──────────────────────────────────────────────── -->
  <div class="content-grid">

    <!-- LEFT: ADD ASSIGNMENT FORM ─────────────────────────────── -->
    <section>
      <div class="card">
        <div class="card-title"><span class="icon">➕</span> Add Assignment</div>

        <!-- Show error messages from redirect query params -->
        <% const errMsg = (typeof error !== 'undefined' && error) ? error : null; %>
        <% if (errMsg) { %>
          <div class="alert" role="alert">⚠️ <%= errMsg %></div>
        <% } %>

        <form id="addForm" action="/assignments" method="POST" novalidate>
          <div class="form-group">
            <label for="title">Title <span style="color:var(--accent)">*</span></label>
            <input
              id="title"
              name="title"
              type="text"
              placeholder="e.g. Algebra Chapter 5 Homework"
              required
              maxlength="150"
            />
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <input
              id="subject"
              name="subject"
              type="text"
              placeholder="e.g. Mathematics"
              maxlength="100"
            />
          </div>

          <div class="form-group">
            <label for="deadline">Deadline <span style="color:var(--accent)">*</span></label>
            <input
              id="deadline"
              name="deadline"
              type="date"
              required
            />
          </div>

          <div class="form-group">
            <label for="status">Initial Status</label>
            <select id="status" name="status">
              <option value="pending">⏳ Pending</option>
              <option value="completed">✅ Completed</option>
            </select>
          </div>

          <button id="submitBtn" class="btn-primary" type="submit">Add Assignment</button>
        </form>
      </div>
    </section>

    <!-- RIGHT: ASSIGNMENT LIST ────────────────────────────────── -->
    <section>
      <div class="card">
        <div class="card-title"><span class="icon">📝</span> Assignments
          <span style="margin-left:auto;font-size:0.75rem;color:var(--text-muted);font-weight:400;">sorted by deadline ↑</span>
        </div>

        <!-- Filter tabs -->
        <div class="filter-bar" role="navigation" aria-label="Assignment filters">
          <a href="/assignments?filter=all"       class="filter-btn <%= activeFilter==='all'       ? 'active' : '' %>">All (<%= stats.totalCount %>)</a>
          <a href="/assignments?filter=pending"   class="filter-btn <%= activeFilter==='pending'   ? 'active' : '' %>">Pending (<%= stats.pendingCount %>)</a>
          <a href="/assignments?filter=completed" class="filter-btn <%= activeFilter==='completed' ? 'active' : '' %>">Completed (<%= stats.completedCount %>)</a>
        </div>

        <!-- Assignment list -->
        <div class="assignment-list" id="assignmentList">
          <% if (assignments.length === 0) { %>
            <div class="empty-state">
              <div class="empty-icon">🎉</div>
              <p>No assignments here — you're all caught up!</p>
            </div>
          <% } else { %>
            <% assignments.forEach(function(a, i) { %>
              <%
                const isOverdue  = a.status === 'pending' && new Date(a.deadline) < now;
                const itemClass  = a.status === 'completed' ? 'completed' : (isOverdue ? 'overdue' : '');
                const deadlineStr = new Date(a.deadline).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'short', day: 'numeric'
                });
              %>
              <div class="assignment-item <%= itemClass %>"
                   style="animation-delay: <%= i * 0.05 %>s"
                   id="assignment-<%= a._id %>">

                <!-- Toggle status button -->
                <form action="/assignments/<%= a._id %>?_method=PUT" method="POST" style="display:inline">
                  <input type="hidden" name="status"
                    value="<%= a.status === 'completed' ? 'pending' : 'completed' %>" />
                  <button type="submit"
                          class="status-toggle"
                          title="<%= a.status === 'completed' ? 'Mark as Pending' : 'Mark as Completed' %>"
                          aria-label="Toggle status">
                    <% if (a.status === 'completed') { %>✓<% } %>
                  </button>
                </form>

                <!-- Assignment info -->
                <div class="assignment-info">
                  <div class="assignment-title" title="<%= a.title %>"><%= a.title %></div>
                  <div class="assignment-meta">
                    <span>📚 <%= a.subject %></span>
                    <span>📅 <%= deadlineStr %></span>
                    <% if (isOverdue) { %>
                      <span class="badge badge-overdue">🔥 Overdue</span>
                    <% } else if (a.status === 'completed') { %>
                      <span class="badge badge-completed">✓ Done</span>
                    <% } else { %>
                      <span class="badge badge-pending">⏳ Pending</span>
                    <% } %>
                  </div>
                </div>

                <!-- Delete button -->
                <form action="/assignments/<%= a._id %>?_method=DELETE" method="POST" style="display:inline"
                      onsubmit="return confirm('Delete this assignment?')">
                  <button type="submit" class="btn-delete" title="Delete assignment" aria-label="Delete">🗑️</button>
                </form>

              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
    </section>

  </div><!-- end .content-grid -->
</main>

<script>
  // ── Client-side form validation before submit ────────────────────
  document.getElementById('addForm').addEventListener('submit', function (e) {
    const title    = document.getElementById('title').value.trim();
    const deadline = document.getElementById('deadline').value;

    if (!title) {
      e.preventDefault();
      alert('⚠️  Please enter an assignment title.');
      document.getElementById('title').focus();
      return;
    }
    if (!deadline) {
      e.preventDefault();
      alert('⚠️  Please select a deadline date.');
      document.getElementById('deadline').focus();
      return;
    }
  });
</script>

</body>
</html>
